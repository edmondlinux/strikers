run = "npm run dev"
modules = ["nodejs-20"]
hidden = [".config", "package-lock.json"]
entrypoint = "index.html"

[nix]
channel = "stable-24_05"
packages = ["python311Packages.ray"]

[unitTest]
language = "nodejs"

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3000

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 40541214
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm install && npm start"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm install && npm run dev"

[[workflows.workflow]]
name = "Backend"
mode = "sequential"
author = 40765742

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mern/backend && node server.js"

[[workflows.workflow]]
name = "Front"
mode = "sequential"
author = 40765742

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mern/frontend && npm run dev"

[agent]
expertMode = true
